<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="group.calculator.Calculator_Controller">
   <children>
      <Label layoutX="34.0" layoutY="42.0" prefHeight="31.0" prefWidth="100.0" text="Enter 1st number" />
      <TextField fx:id="CalculatorInputField1" layoutX="134.0" layoutY="46.0" prefHeight="25.0" prefWidth="112.0" />
      <Label layoutX="326.0" layoutY="46.0" prefHeight="31.0" prefWidth="100.0" text="Enter 2nd number" />
      <TextField fx:id="CalculatorInputField2" layoutX="426.0" layoutY="50.0" prefHeight="25.0" prefWidth="112.0" />
      <Button layoutX="127.0" layoutY="103.0" mnemonicParsing="false" onAction="#CalculatorAddButton" prefHeight="31.0" prefWidth="63.0" text="+">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <Button layoutX="200.0" layoutY="103.0" mnemonicParsing="false" onAction="#CalculatorSubButton" prefHeight="31.0" prefWidth="63.0" text="-">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <Button layoutX="275.0" layoutY="103.0" mnemonicParsing="false" onAction="#CalculatorMulButton" prefHeight="31.0" prefWidth="63.0" text="*">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <Button layoutX="348.0" layoutY="103.0" mnemonicParsing="false" onAction="#CalculatorDivButton" prefHeight="31.0" prefWidth="63.0" text="/">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <Label fx:id="CalculatorResult" layoutX="146.0" layoutY="186.0" prefHeight="31.0" prefWidth="221.0" style="-fx-background-color: yellow;" text="Result: ">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
